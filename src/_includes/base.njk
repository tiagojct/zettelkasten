<!DOCTYPE html>
<html lang="pt-PT">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title if title else "Zettelkasten público" }}{{ " — caderno de notas" if not title else "" }}</title>
  <meta name="description" content="Bloco de notas público de Tiago Jacinto. Zettelkasten aberto.">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  {% if page.url %}
  {% set isNotePage = page.url | replace('/zettelkasten/', '/') %}
  {% set isNote = '/notas/' in isNotePage %}
  {% set isGrafo = '/grafo/' in page.url %}
  {% else %}
  {% set isNote = false %}
  {% set isGrafo = false %}
  {% endif %}
  {% if isNote or isGrafo %}
  <script src="https://d3js.org/d3.v7.min.js"></script>
  {% endif %}
</head>
<body>
  <script>window.ZETTEL_BASE = "/zettelkasten";</script>
  <header class="site-header">
    <nav class="site-nav">
      <a href="{{ '/' | url }}" class="nav-brand">Zettelkasten</a>
      <span class="nav-sep" aria-hidden="true">·</span>
      <a href="{{ '/' | url }}">notas</a>
      <a href="{{ '/tags/' | url }}">temas</a>
      <a href="{{ '/grafo/' | url }}">grafo</a>
      <a href="{{ '/aleatoria/' | url }}" class="nav-random" title="Nota aleatória">aleatória</a>
    </nav>
  </header>
  <main class="site-main">
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <p>Zettelkasten público de <a href="https://tiagojct.eu">Tiago Jacinto</a>.</p>
  </footer>
</body>
</html>
